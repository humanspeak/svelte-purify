{
    "name": "docs",
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "build": "vite build",
        "cf-typegen": "wrangler types && mv worker-configuration.d.ts src/",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "deploy": "pnpm run build && wrangler pages deploy",
        "dev": "vite dev",
        "format": "prettier --write .",
        "generate-social": "tsx scripts/generate-social-images.ts",
        "lint": "prettier --check . && eslint .",
        "lint:fix": "pnpm run format && eslint . --fix",
        "preview": "vite preview",
        "sitemap:manifest": "node ./scripts/generate-sitemap-manifest.mjs",
        "sitemap:watch": "chokidar 'src/routes/**/*.svelte' 'src/routes/**/*.svx' 'src/routes/**/*.md' --ignore 'src/routes/examples/+page.ts' -c 'node ./scripts/generate-sitemap-manifest.mjs' --initial --silent",
        "test": "pnpm run test:unit -- --run && pnpm run test:e2e",
        "test:e2e": "playwright test",
        "test:unit": "vitest"
    },
    "overrides": {
        "@sveltejs/adapter-cloudflare": {
            "esbuild": "^0.25.0"
        },
        "@sveltejs/kit": {
            "cookie": "^0.7.0"
        },
        "mdsvex": {
            "prismjs": "^1.29.0"
        },
        "wrangler": {
            "esbuild": "^0.25.0"
        },
        "youch": {
            "cookie": "^0.7.0"
        }
    },
    "dependencies": {
        "@humanspeak/svelte-motion": "^0.5.3",
        "@humanspeak/svelte-purify": "file:..",
        "@sentry/cloudflare": "^10.54.0",
        "@sentry/sveltekit": "^10.54.0",
        "posthog-js": "^1.376.3"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260527.1",
        "@eslint/compat": "^2.1.0",
        "@internationalized/date": "^3.12.1",
        "@lucide/svelte": "^1.16.0",
        "@playwright/test": "^1.60.0",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/kit": "^2.61.1",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/aspect-ratio": "^0.4.2",
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.3.0",
        "@types/eslint": "^9.6.1",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "autoprefixer": "^10.5.0",
        "bits-ui": "^2.18.1",
        "chokidar-cli": "^3.0.0",
        "clsx": "^2.1.1",
        "concurrently": "^9.2.1",
        "embla-carousel-svelte": "^8.6.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-svelte": "^3.18.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "formsnap": "^2.0.1",
        "globals": "^17.6.0",
        "highlight.js": "^11.11.1",
        "layerchart": "^2.0.0-next.10",
        "lucide-svelte": "^1.0.1",
        "mdsvex": "^0.12.7",
        "mode-watcher": "^1.1.0",
        "paneforge": "^1.0.2",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-svelte": "^4.0.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "puppeteer": "^25.1.0",
        "shiki": "^4.1.0",
        "svelte": "^5.55.9",
        "svelte-check": "^4.4.8",
        "svelte-sonner": "^1.1.1",
        "sveltekit-superforms": "^2.30.1",
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.22.3",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vaul-svelte": "^1.0.0-next.7",
        "vite": "^8.0.14",
        "vitest": "^4.1.7",
        "wrangler": "^4.95.0",
        "zod": "^4.4.3"
    },
    "volta": {
        "node": "24.15.0"
    }
}
